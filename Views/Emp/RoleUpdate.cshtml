@model employee_management_agile.Models.EmpModel;

<h2>Update Role</h2>

<form asp-action="RoleUpdate" method="post">
    <input type="hidden" asp-for="Id" />
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" readonly />
    </div>
    <div class="form-group">
        <label asp-for="Position"></label>
        <input asp-for="Position" class="form-control" readonly />
    </div>
    <div class="form-group">
        <label asp-for="Department"></label>
        <input asp-for="Department" class="form-control" readonly />
    </div>
    <!-- Add role selection here -->
    <button type="submit" class="btn btn-primary">Update Role</button>
    <a asp-action="GetAllEmployees" class="btn btn-link">Back to List</a>
</form>
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}